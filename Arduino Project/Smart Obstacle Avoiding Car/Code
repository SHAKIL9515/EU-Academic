#include <Servo.h>
#include <AFMotor.h>
#include <ctype.h>
#include <string.h>

// Front ultrasonic (servo-mounted)
#define frontEcho A0
#define frontTrig A1

// Button
#define button A2

// Rear ultrasonic
#define rearTrig A4
#define rearEcho A5

// Servo
#define servoPin 10

// Outputs
#define obstacleBuzzer 2
#define reverseBuzzer 4
#define reverseLED 9
#define headLight 12

// Servo positions
#define spoint 85
#define rightPoint 20
#define leftPoint 160

// Distance thresholds (cm)
#define frontObstacleDistance 15
#define rearObstacleDistance 15

char commandBuffer[32];
byte commandIndex = 0;
int frontDistance;
int rearDistance;
int L = 0, R = 0;

// Modes
bool isObstacleMode = false;
bool isBluetoothMode = false;

// Reverse system
bool reverseActive = false;
unsigned long lastBlinkTime = 0;
bool ledState = false;

// Headlight
bool headLightOn = false;

unsigned long lastButtonPress = 0;
unsigned long lastManualAlertCheck = 0;
bool manualCheckFrontNext = true;
int manualFrontDistance = 100;
int manualRearDistance = 100;

Servo servo;
AF_DCMotor M1(1);
AF_DCMotor M2(2);
AF_DCMotor M3(3);
AF_DCMotor M4(4);

void processCommand(char *cmd);
void updateManualObstacleAlert();

void setup() {
  Serial.begin(9600);

  pinMode(frontTrig, OUTPUT);
  pinMode(frontEcho, INPUT);
  pinMode(rearTrig, OUTPUT);
  pinMode(rearEcho, INPUT);
  pinMode(button, INPUT_PULLUP);

  pinMode(obstacleBuzzer, OUTPUT);
  pinMode(reverseBuzzer, OUTPUT);
  pinMode(reverseLED, OUTPUT);
  pinMode(headLight, OUTPUT);

  digitalWrite(obstacleBuzzer, LOW);
  digitalWrite(reverseBuzzer, LOW);
  digitalWrite(reverseLED, LOW);
  digitalWrite(headLight, LOW);

  servo.attach(servoPin);

  M1.setSpeed(180);
  M2.setSpeed(180);
  M3.setSpeed(180);
  M4.setSpeed(180);

  servo.write(spoint);
  delay(1000);
}

void loop() {
  checkButton();
  Bluetoothcontrol();
  updateHeadLight();
  updateReverseAlert();

  if (isObstacleMode) {
    Obstacle();
  } else if (isBluetoothMode) {
    updateManualObstacleAlert();
  } else {
    Stop();
    digitalWrite(obstacleBuzzer, LOW);
  }
}

void checkButton() {
  if (digitalRead(button) == LOW && millis() - lastButtonPress > 250) {
    lastButtonPress = millis();

    if (!isObstacleMode && !isBluetoothMode) {
      isObstacleMode = true;
    } else if (isObstacleMode) {
      isObstacleMode = false;
      isBluetoothMode = true;
      servo.write(spoint);
    } else {
      isBluetoothMode = false;
    }

    Stop();
  }
}

void updateHeadLight() {
  digitalWrite(headLight, headLightOn ? HIGH : LOW);
}

void updateReverseAlert() {
  if (reverseActive) {
    if (millis() - lastBlinkTime >= 333) {
      ledState = !ledState;
      digitalWrite(reverseLED, ledState);
      digitalWrite(reverseBuzzer, ledState);
      lastBlinkTime = millis();
    }
  } else {
    digitalWrite(reverseLED, LOW);
    digitalWrite(reverseBuzzer, LOW);
  }
}

void Obstacle() {
  frontDistance = frontUltrasonicAt(spoint);

  if (frontDistance > frontObstacleDistance) {
    digitalWrite(obstacleBuzzer, LOW);
    forward();
    return;
  }

  handleFrontObstacle();
}

void handleFrontObstacle() {
  Stop();
  digitalWrite(obstacleBuzzer, HIGH);
  delay(250);

  rearDistance = rearUltrasonic();

  if (rearDistance <= rearObstacleDistance) {
    servo.write(spoint);
    Stop();
    return;
  }

  backward();
  delay(300);
  Stop();

  L = leftsee();
  delay(200);
  R = rightsee();
  delay(200);

  servo.write(spoint);
  delay(200);

  digitalWrite(obstacleBuzzer, LOW);

  if (L < R) {
    right();
    delay(400);
  } else {
    left();
    delay(400);
  }

  Stop();
}

void Bluetoothcontrol() {
  while (Serial.available()) {
    char c = Serial.read();
    if (c == '\n' || c == '\r') {
      if (commandIndex > 0) {
        commandBuffer[commandIndex] = '\0';
        processCommand(commandBuffer);
        commandIndex = 0;
      }
    } else if (commandIndex < sizeof(commandBuffer) - 1) {
      commandBuffer[commandIndex++] = tolower(c);
    }
  }

  if (commandIndex > 0) {
    commandBuffer[commandIndex] = '\0';
    processCommand(commandBuffer);
    commandIndex = 0;
  }
}

void forward() {
  reverseActive = false;
  M1.run(FORWARD);
  M2.run(FORWARD);
  M3.run(FORWARD);
  M4.run(FORWARD);
}

void backward() {
  reverseActive = true;
  M1.run(BACKWARD);
  M2.run(BACKWARD);
  M3.run(BACKWARD);
  M4.run(BACKWARD);
}

void right() {
  reverseActive = false;
  M1.run(FORWARD);
  M2.run(FORWARD);
  M3.run(BACKWARD);
  M4.run(BACKWARD);
}

void left() {
  reverseActive = false;
  M1.run(BACKWARD);
  M2.run(BACKWARD);
  M3.run(FORWARD);
  M4.run(FORWARD);
}

void Stop() {
  reverseActive = false;
  M1.run(RELEASE);
  M2.run(RELEASE);
  M3.run(RELEASE);
  M4.run(RELEASE);
}

int readUltrasonic(int trigPin, int echoPin) {
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  long t = pulseIn(echoPin, HIGH, 30000);
  if (t == 0) return 100;

  return t / 29 / 2;
}

int frontUltrasonicAt(int angle) {
  servo.write(angle);
  delay(450);
  return readUltrasonic(frontTrig, frontEcho);
}

int rearUltrasonic() {
  return readUltrasonic(rearTrig, rearEcho);
}

int rightsee() {
  return frontUltrasonicAt(rightPoint);
}

int leftsee() {
  return frontUltrasonicAt(leftPoint);
}

void updateManualObstacleAlert() {
  if (millis() - lastManualAlertCheck >= 120) {
    lastManualAlertCheck = millis();

    if (manualCheckFrontNext) {
      servo.write(spoint);
      delay(70);
      manualFrontDistance = readUltrasonic(frontTrig, frontEcho);
    } else {
      manualRearDistance = rearUltrasonic();
    }

    manualCheckFrontNext = !manualCheckFrontNext;
  }

  if (manualFrontDistance <= frontObstacleDistance || manualRearDistance <= rearObstacleDistance) {
    digitalWrite(obstacleBuzzer, HIGH);
  } else {
    digitalWrite(obstacleBuzzer, LOW);
  }
}

void processCommand(char *cmd) {
  if (strcmp(cmd, "1") == 0) {
    isObstacleMode = true;
    isBluetoothMode = false;
    Stop();
  } else if (strcmp(cmd, "2") == 0) {
    isObstacleMode = false;
    isBluetoothMode = true;
    servo.write(spoint);
    Stop();
  } else if (strcmp(cmd, "u") == 0 || strcmp(cmd, "forward") == 0 || strcmp(cmd, "go") == 0) {
    forward();
  } else if (strcmp(cmd, "d") == 0 || strcmp(cmd, "backward") == 0 || strcmp(cmd, "back") == 0) {
    backward();
  } else if (strcmp(cmd, "l") == 0 || strcmp(cmd, "left") == 0 || strcmp(cmd, "turn left") == 0) {
    left();
  } else if (strcmp(cmd, "r") == 0 || strcmp(cmd, "right") == 0 || strcmp(cmd, "turn right") == 0) {
    right();
  } else if (strcmp(cmd, "s") == 0 || strcmp(cmd, "stop") == 0) {
    Stop();
  } else if (strcmp(cmd, "3") == 0) {
    headLightOn = true;
  } else if (strcmp(cmd, "4") == 0) {
    headLightOn = false;
  }
}
